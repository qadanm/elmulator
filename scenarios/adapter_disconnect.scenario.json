{
  "schema_version": "obd2.sim_scenario.v1",
  "scenario_id": "adapter_disconnect",
  "synthetic": true,
  "description": "Adapter stalls once on 0100 (session must time out and retry), answers the retry, then drops the connection on 03. The scan must fail with a typed transport-ended error, never a crash or fake data.",
  "adapter_profile": "elm327_like_tcp",
  "defaults": {
    "at_response": "OK\r\r>",
    "obd_response": "NO DATA\r\r>"
  },
  "stream_split_bytes": null,
  "warnings": [
    "first 0100 entry stalls on purpose to exercise timeout and retry",
    "03 entry disconnects on purpose"
  ],
  "commands": [
    { "request": "ATZ", "response_chunks": ["ELM327 v1.5\r\r>"], "delay_ms": 5, "echo": true },
    { "request": "ATE0", "response_chunks": ["OK\r\r>"], "delay_ms": 3, "echo": true },
    { "request": "ATL0", "response_chunks": ["OK\r\r>"], "delay_ms": 3, "echo": false },
    { "request": "ATH1", "response_chunks": ["OK\r\r>"], "delay_ms": 3, "echo": false },
    { "request": "ATSP0", "response_chunks": ["OK\r\r>"], "delay_ms": 3, "echo": false },
    { "request": "0100", "response_chunks": [], "delay_ms": 0, "echo": false, "prompt": false, "post_action": "stall" },
    { "request": "0100", "response_chunks": ["7E8 06 41 00 BE 3E B8 11\r\r>"], "delay_ms": 5, "echo": false },
    { "request": "0120", "response_chunks": ["7E8 06 41 20 80 00 00 00\r\r>"], "delay_ms": 5, "echo": false },
    { "request": "0101", "response_chunks": ["7E8 06 41 01 00 07 E5 00\r\r>"], "delay_ms": 5, "echo": false },
    { "request": "03", "response_chunks": [], "delay_ms": 0, "echo": false, "prompt": false, "post_action": "disconnect" }
  ],
  "expected_scan_summary": {
    "scan_error": "transport_ended"
  }
}
